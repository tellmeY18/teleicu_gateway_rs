# ──────────────────────────────────────────────
# TeleICU Gateway — Environment Configuration
# Copy to .env and adjust as needed.
# ──────────────────────────────────────────────

# ── Required ──────────────────────────────────
# Unique device ID registered in CARE for this gateway
GATEWAY_DEVICE_ID=

# ── Server ────────────────────────────────────
BIND_HOST=0.0.0.0
BIND_PORT=8090

# ── Database ──────────────────────────────────
# mode=rwc creates the file if it doesn't exist
DATABASE_URL=sqlite:./gateway.db?mode=rwc

# ── Persistent state (keypair, etc.) ──────────
STATE_DIR=./data

# ── CARE backend ──────────────────────────────
CARE_API=https://care.10bedicu.in
CARE_API_TIMEOUT_SECS=25

# ── RTSPtoWeb ─────────────────────────────────
RTSPTOWEB_URL=http://localhost:8080

# ── Identity ──────────────────────────────────
HOST_NAME=gateway

# ── Automated observations ────────────────────
# Enabled automatically when GATEWAY_DEVICE_ID is set
# AUTOMATED_OBSERVATIONS_ENABLED=true
AUTOMATED_OBSERVATIONS_INTERVAL_MINS=60

# ── Camera settings ───────────────────────────
CAMERA_LOCK_TIMEOUT_SECS=120
ONVIF_ACCEPT_INVALID_CERTS=true

# ── Logging ───────────────────────────────────
RUST_LOG=info,teleicu_gateway=debug

# ── Optional: RSA keypair override ────────────
# Base64-encoded JWK keyset. Leave empty to auto-generate on first run.
# JWKS_BASE64=

# ── Optional: credential encryption at rest ───
# ENCRYPTION_KEY=

# ── Optional: S3 archival (all four required) ─
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_ENDPOINT_URL=

# ── Optional: error tracking ─────────────────
# SENTRY_DSN=
